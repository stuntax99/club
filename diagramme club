function svgToDataUri(s) {
  return 'data:image/svg+xml;base64,' + btoa(unescape(encodeURIComponent(s)));
}

const FEN_MAP = {
  'K':'wK','Q':'wQ','R':'wR','B':'wB','N':'wN','P':'wP',
  'k':'bK','q':'bQ','r':'bR','b':'bB','n':'bN','p':'bP'
};

const DEFAULT_FEN = 'r2q1rk1/ppb2ppp/3p1n2/4p3/4P3/2N1BN2/PPP2PPP/R2Q1RK1 w - - 0 1';
let currentFen = DEFAULT_FEN;
let flipped = false;
let currentTurn = 'none';

function parseFen(fen) {
  const parts = fen.trim().split(/\s+/);
  const rows  = parts[0].split('/');
  if (rows.length !== 8) return null;
  const board = [];
  for (const row of rows) {
    const rank = [];
    for (const ch of row) {
      if (/\d/.test(ch)) { for (let i=0;i<+ch;i++) rank.push(''); }
      else { const pc = FEN_MAP[ch]; if (!pc) return null; rank.push(pc); }
    }
    if (rank.length !== 8) return null;
    board.push(rank);
  }
  return board;
}

function renderBoard() {
  const board = parseFen(currentFen);
  if (!board) return;

  const F_NORM = ['a','b','c','d','e','f','g','h'];
  const F_FLIP = ['h','g','f','e','d','c','b','a'];
  const files  = flipped ? F_FLIP : F_NORM;

  // Rank labels
  const rl = document.getElementById('rankLabels');
  rl.innerHTML = '';
  for (let r=0; r<8; r++) {
    const d = document.createElement('div');
    d.className = 'rank-label';
    d.textContent = flipped ? r+1 : 8-r;
    rl.appendChild(d);
  }

  // File labels
  const fl = document.getElementById('fileLabels');
  fl.innerHTML = '';
  files.forEach(lbl => {
    const d = document.createElement('div');
    d.className = 'file-label'; d.textContent = lbl; fl.appendChild(d);
  });

  // Squares
  const boardEl = document.getElementById('board');
  boardEl.innerHTML = '';
  for (let ri=0; ri<8; ri++) {
    for (let fi=0; fi<8; fi++) {
      const ari = flipped ? 7-ri : ri;
      const afi = flipped ? 7-fi : fi;
      const pc  = board[ari][afi];
      const sq  = document.createElement('div');
      sq.className = 'square ' + ((ri+fi)%2===0 ? 'light' : 'dark');
      if (pc && PIECES_SVG[pc]) sq.innerHTML = PIECES_SVG[pc];
      boardEl.appendChild(sq);
    }
  }
}

function setTurn(t) {
  currentTurn = t;
  ['none','w','b'].forEach(v => {
    const btn = document.getElementById('turn' + (v==='none'?'None':v==='w'?'W':'B'));
    if(btn) btn.classList.toggle('active', v===t);
  });
  const footer = document.getElementById('cardFooter');
  const dot    = document.getElementById('turnDot');
  if(t === 'none') { footer.style.display='none'; }
  else { footer.style.display='flex'; dot.className='turn-dot '+(t==='w'?'white':'black'); }
}

function applyFen() {
  const val = document.getElementById('fenInput').value.trim();
  const fen = val || DEFAULT_FEN;
  const errEl = document.getElementById('fenError');
  if (!parseFen(fen)) { errEl.style.display='block'; return; }
  errEl.style.display = 'none';
  currentFen = fen;
  renderBoard();
}

function setFlip(f) {
  flipped = f;
  document.getElementById('toggleW').classList.toggle('active', !f);
  document.getElementById('toggleB').classList.toggle('active',  f);
  renderBoard();
}

// ── PNG EXPORT ──────────────────────────────────────────────────────────
async function downloadPNG() {
  const btn = document.getElementById('pngBtn');
  btn.textContent = '⏳ Génération…'; btn.disabled = true;

  const scale  = 3;
  const MARGIN = 24;
  const CW     = 500;
  const PAD    = 28;
  const RLBL   = 16;
  const SQ     = Math.floor((CW - PAD*2 - RLBL) / 8);
  const BW     = SQ * 8;

  const HEADER_H = 88;
  const BOARD_TOP = HEADER_H + 22;
  const CH = BOARD_TOP + BW + 16 + (currentTurn!=='none'?44:22);

  const TW = CW + MARGIN*2;
  const TH = CH + MARGIN*2;
  const CX = MARGIN, CY = MARGIN;

  const canvas = document.createElement('canvas');
  canvas.width  = TW * scale;
  canvas.height = TH * scale;
  const ctx = canvas.getContext('2d');
  ctx.scale(scale, scale);

  function rr(x,y,w,h,r) {
    ctx.beginPath();
    ctx.moveTo(x+r,y); ctx.lineTo(x+w-r,y); ctx.quadraticCurveTo(x+w,y,x+w,y+r);
    ctx.lineTo(x+w,y+h-r); ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
    ctx.lineTo(x+r,y+h); ctx.quadraticCurveTo(x,y+h,x,y+h-r);
    ctx.lineTo(x,y+r); ctx.quadraticCurveTo(x,y,x+r,y);
    ctx.closePath();
  }

  // Background
  const bg = ctx.createRadialGradient(TW*.4,TH*.4,0,TW*.4,TH*.4,500);
  bg.addColorStop(0,'#0e0e1c'); bg.addColorStop(1,'#050507');
  ctx.fillStyle = bg; ctx.fillRect(0,0,TW,TH);

  // Card
  ctx.save(); rr(CX,CY,CW,CH,22);
  const cg = ctx.createLinearGradient(CX,CY,CX+CW*.6,CY+CH);
  cg.addColorStop(0,'#17172a'); cg.addColorStop(.6,'#0e0e18'); cg.addColorStop(1,'#0b0b14');
  ctx.fillStyle=cg; ctx.fill();
  ctx.strokeStyle='rgba(212,168,67,.2)'; ctx.lineWidth=1; ctx.stroke(); ctx.restore();

  // Gold top line
  const gg = ctx.createLinearGradient(CX,0,CX+CW,0);
  gg.addColorStop(0,'rgba(0,0,0,0)'); gg.addColorStop(.25,'#d4a843');
  gg.addColorStop(.5,'#f0c96a'); gg.addColorStop(.75,'#d4a843');
  gg.addColorStop(1,'rgba(0,0,0,0)');
  ctx.fillStyle=gg; ctx.fillRect(CX,CY,CW,2.5);

  // Header
  const hPAD = CX+PAD;
  const hY   = CY+20;
  ctx.fillStyle='#d4a843'; ctx.font='22px serif';
  ctx.fillText('♟', hPAD, hY+28);
  ctx.fillStyle='#e8d5a0'; ctx.font='bold 17px Georgia,serif';
  ctx.fillText('Club ', hPAD+28, hY+26);
  const cw2 = ctx.measureText('Club ').width;
  ctx.fillStyle='#d4a843'; ctx.font='italic 17px Georgia,serif';
  ctx.fillText('Blitzstream', hPAD+28+cw2, hY+26);
  ctx.fillStyle='rgba(212,168,67,.45)'; ctx.font='500 8px Arial,sans-serif';
  

  // Tag pill
  const tw=90, th=24, tx=CX+CW-PAD-tw, ty=hY+6;
  ctx.save(); rr(tx,ty,tw,th,12);
  ctx.fillStyle='rgba(212,168,67,.08)'; ctx.fill();
  ctx.strokeStyle='rgba(212,168,67,.28)'; ctx.lineWidth=1; ctx.stroke();
  ctx.fillStyle='#d4a843'; ctx.font='700 10px Arial,sans-serif';
  ctx.textAlign='center'; ctx.fillText('POSITION', tx+tw/2, ty+16);
  ctx.textAlign='left'; ctx.restore();

  // Header sep
  const sg = ctx.createLinearGradient(hPAD,0,CX+CW-PAD,0);
  sg.addColorStop(0,'rgba(0,0,0,0)'); sg.addColorStop(.5,'rgba(212,168,67,.14)'); sg.addColorStop(1,'rgba(0,0,0,0)');
  ctx.fillStyle=sg; ctx.fillRect(hPAD, CY+HEADER_H-6, CW-PAD*2, 1);

  // Board
  const bX = CX + PAD + RLBL;
  const bY = CY + BOARD_TOP;
  const F_NORM = ['a','b','c','d','e','f','g','h'];
  const F_FLIP = ['h','g','f','e','d','c','b','a'];
  const files  = flipped ? F_FLIP : F_NORM;

  for (let ri=0;ri<8;ri++) for (let fi=0;fi<8;fi++) {
    ctx.fillStyle = (ri+fi)%2===0 ? '#f0d9b5' : '#b58863';
    ctx.fillRect(bX+fi*SQ, bY+ri*SQ, SQ, SQ);
  }
  ctx.strokeStyle='rgba(0,0,0,.55)'; ctx.lineWidth=1;
  ctx.strokeRect(bX, bY, BW, BW);

  // Pieces
  const board = parseFen(currentFen);
  const jobs  = [];
  for (let ri=0; ri<8; ri++) for (let fi=0; fi<8; fi++) {
    const ari = flipped ? 7-ri : ri;
    const afi = flipped ? 7-fi : fi;
    const pc  = board[ari][afi];
    if (!pc || !PIECES_SVG[pc]) continue;
    const img = new Image();
    const _ri=ri, _fi=fi;
    jobs.push(new Promise(res => {
      img.onload = () => { const m=SQ*.05; ctx.drawImage(img, bX+_fi*SQ+m, bY+_ri*SQ+m, SQ-m*2, SQ-m*2); res(); };
      img.onerror = res;
      img.src = svgToDataUri(PIECES_SVG[pc]);
    }));
  }
  await Promise.all(jobs);

  // Rank labels
  ctx.fillStyle='#38385a'; ctx.font='500 10px Arial,sans-serif'; ctx.textAlign='center';
  for (let r=0; r<8; r++) ctx.fillText(flipped?r+1:8-r, CX+PAD+RLBL/2, bY+r*SQ+SQ/2+3);

  // File labels
  for (let f=0; f<8; f++) ctx.fillText(files[f], bX+f*SQ+SQ/2, bY+BW+13);
  ctx.textAlign='left';

  // Turn dot
  if (currentTurn !== 'none') {
    const dotX = CX+PAD+RLBL+8, dotY = bY+BW+32;
    ctx.save();
    ctx.beginPath(); ctx.arc(dotX, dotY, 7, 0, Math.PI*2);
    if(currentTurn==='w'){
      const dg=ctx.createRadialGradient(dotX-2,dotY-2,0,dotX,dotY,7);
      dg.addColorStop(0,'#fff');dg.addColorStop(1,'#ccc');
      ctx.fillStyle=dg;ctx.fill();
      ctx.strokeStyle='rgba(0,0,0,.25)';ctx.lineWidth=1.5;ctx.stroke();
    } else {
      const dg=ctx.createRadialGradient(dotX-2,dotY-2,0,dotX,dotY,7);
      dg.addColorStop(0,'#555');dg.addColorStop(1,'#111');
      ctx.fillStyle=dg;ctx.fill();
      ctx.strokeStyle='rgba(255,255,255,.15)';ctx.lineWidth=1.5;ctx.stroke();
    }
    ctx.restore();
  }

  // Gold bottom line
  ctx.fillStyle=gg; ctx.fillRect(CX, CY+CH-2, CW, 2);

  // Download
  const a = document.createElement('a');
  a.href = canvas.toDataURL('image/png');
  a.download = 'diagramme-blitzstream.png';
  a.click();

  btn.textContent = '🖼 Télécharger PNG'; btn.disabled = false;
}

// Init
renderBoard();
</script>
