<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Puzzle Blitzstream</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Roboto:wght@400;700;900&display=swap');
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Roboto', sans-serif;
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        
        .puzzle-container {
            background: #1a1a1a;
            border-radius: 20px;
            padding: 40px;
            max-width: 900px;
            width: 100%;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
            position: relative;
            overflow: hidden;
        }
        
        .puzzle-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: 
                repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(255,255,255,.03) 35px, rgba(255,255,255,.03) 70px);
            pointer-events: none;
        }
        
        .content {
            position: relative;
            z-index: 1;
        }
        
        .subtitle {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.8em;
            color: white;
            text-align: center;
            letter-spacing: 2px;
            margin-bottom: 5px;
        }
        
        .event {
            font-size: 0.9em;
            color: #999;
            text-align: center;
            margin-bottom: 30px;
            font-weight: 300;
        }
        
        .trait {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2.5em;
            color: white;
            text-align: center;
            letter-spacing: 3px;
            margin-bottom: 15px;
        }
        
        .stars {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-bottom: 30px;
        }
        
        .star {
            font-size: 2em;
            color: #ff4757;
            text-shadow: 0 0 10px rgba(255, 71, 87, 0.5);
        }
        
        .star.empty {
            color: #444;
        }
        
        .board-container {
            display: flex;
            justify-content: center;
            margin-bottom: 30px;
        }
        
        .chessboard {
            display: grid;
            grid-template-columns: repeat(8, 90px);
            grid-template-rows: repeat(8, 90px);
            border: 8px solid #8B7355;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
        }
        
        .square {
            width: 90px;
            height: 90px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }
        
        .square.light {
            background: #F0D9B5;
        }
        
        .square.dark {
            background: #B58863;
        }
        
        .coordinate {
            position: absolute;
            font-size: 11px;
            font-weight: bold;
            color: #8B7355;
        }
        
        .file-coord {
            bottom: 2px;
            right: 4px;
        }
        
        .rank-coord {
            top: 2px;
            left: 4px;
        }
        
        .piece {
            width: 75px;
            height: 75px;
        }

        @media (max-width: 768px) {
            .chessboard {
                grid-template-columns: repeat(8, 50px);
                grid-template-rows: repeat(8, 50px);
            }
            .square {
                width: 50px;
                height: 50px;
            }
            .piece {
                width: 42px;
                height: 42px;
            }
            .subtitle {
                font-size: 1.2em;
            }
        }
    </style>
</head>
