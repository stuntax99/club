    ctx.fillStyle='#d4a843';ctx.font='700 9px Arial,sans-serif';ctx.textAlign='center';ctx.fillText(String(p+1),badgeX+9,badgeY+13);ctx.textAlign='left';
    ctx.fillStyle='rgba(212,168,67,.45)';ctx.font='700 8px Arial,sans-serif';ctx.fillText('PUZZLE '+(p+1),badgeX+22,badgeY+12);

    const bY=oy+PUZ_TOP+PUZ_NUM_H,bX=ox+RLBL;
    for(let ri=0;ri<8;ri++)for(let fi=0;fi<8;fi++){ctx.fillStyle=(ri+fi)%2===0?'#f0d9b5':'#b58863';ctx.fillRect(bX+fi*SQ,bY+ri*SQ,SQ,SQ);}
    ctx.strokeStyle='rgba(0,0,0,.5)';ctx.lineWidth=1;ctx.strokeRect(bX,bY,BW,BW);
    for(let dri=0;dri<8;dri++){for(let dfi=0;dfi<8;dfi++){const ari=f?7-dri:dri,afi=f?7-dfi:dfi,pc=pos.board[ari][afi];if(!pc||!PIECES_SVG[pc])continue;const img=new Image();const _dri=dri,_dfi=dfi;allJobs.push(new Promise(res=>{img.onload=()=>{const m=SQ*.05;ctx.drawImage(img,bX+_dfi*SQ+m,bY+_dri*SQ+m,SQ-m*2,SQ-m*2);res();};img.onerror=res;img.src=svgToDataUri(PIECES_SVG[pc]);}));}}
    ctx.fillStyle='#38385a';ctx.font='500 9px Arial,sans-serif';ctx.textAlign='center';
    for(let r=0;r<8;r++)ctx.fillText(f?r+1:8-r,ox+RLBL/2,bY+r*SQ+SQ/2+3);
    for(let fi=0;fi<8;fi++)ctx.fillText(files[fi],bX+fi*SQ+SQ/2,bY+BW+11);
    ctx.textAlign='left';
    const fY=bY+BW+FLBL_H+10;
    ctx.save();ctx.beginPath();ctx.arc(ox+6,fY,6,0,Math.PI*2);
    if(s.turn==='b'){const dg=ctx.createRadialGradient(ox+4,fY-2,0,ox+6,fY,6);dg.addColorStop(0,'#555');dg.addColorStop(1,'#111');ctx.fillStyle=dg;ctx.fill();ctx.strokeStyle='rgba(255,255,255,.15)';ctx.lineWidth=.8;ctx.stroke();}
    else{const dg=ctx.createRadialGradient(ox+4,fY-2,0,ox+6,fY,6);dg.addColorStop(0,'#fff');dg.addColorStop(1,'#ccc');ctx.fillStyle=dg;ctx.fill();ctx.strokeStyle='rgba(0,0,0,.25)';ctx.lineWidth=.8;ctx.stroke();ctx.shadowColor='rgba(255,255,255,.4)';ctx.shadowBlur=5;ctx.stroke();}
    ctx.restore();
    ctx.fillStyle='#c8bea4';ctx.font='italic 13px Georgia,serif';ctx.fillText(s.turn==='b'?'Trait aux noirs':'Trait aux blancs',ox+16,fY+4);
    const starsRight=ox+colW;ctx.fillStyle='#555570';ctx.font='600 7.5px Arial,sans-serif';ctx.textAlign='right';ctx.fillText('DIFF.',starsRight,fY-5);
    for(let i=1;i<=5;i++){ctx.fillStyle=i<=s.difficulty?'#d4a843':'#1e1e30';if(i<=s.difficulty){ctx.shadowColor='rgba(212,168,67,.45)';ctx.shadowBlur=5;}else ctx.shadowBlur=0;ctx.font='15px Arial,sans-serif';ctx.fillText('★',starsRight-(5-i+1)*17,fY+6);}
    ctx.shadowBlur=0;ctx.textAlign='left';
  }
  await Promise.all(allJobs);
  ctx.fillStyle=gg;ctx.fillRect(CX,CY+CH-2,CW,2);
  const a=document.createElement('a');a.href=canvas.toDataURL('image/png');a.download=`puzzles-blitzstream-${n}x.png`;a.click();
  btn.textContent='🖼 PNG';btn.disabled=false;
}

buildHTML();
for(let i=0;i<4;i++)renderBoard(i);
updateDividers(4);
</script>
