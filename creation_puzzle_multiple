function svgToDataUri(s){return'data:image/svg+xml;base64,'+btoa(unescape(encodeURIComponent(s)))}
const FEN_MAP={'K':'wK','Q':'wQ','R':'wR','B':'wB','N':'wN','P':'wP','k':'bK','q':'bQ','r':'bR','b':'bB','n':'bN','p':'bP'};
const DEFAULT_FENS=['r2q1rk1/ppb2ppp/3p1n2/4p3/4P3/2N1BN2/PPP2PPP/R2Q1RK1 w - - 0 1','r1bqkb1r/pppp1ppp/2n2n2/4p3/2B1P3/5N2/PPPP1PPP/RNBQK2R w KQkq - 4 4','6k1/5ppp/8/8/8/8/5PPP/4R1K1 w - - 0 1','r3r1k1/pp3pbp/2p3p1/q7/3P4/2N1BN2/PP3PPP/R2QR1K1 b - - 0 1'];
let puzzleCount=4;
const state=Array.from({length:4},(_,i)=>({fen:DEFAULT_FENS[i],turn:i===3?'b':'w',difficulty:2,flipped:false}));

function parseFen(fen){
  const parts=fen.trim().split(/\s+/),rows=parts[0].split('/');
  if(rows.length!==8)return null;
  const board=[];
  for(const row of rows){const rank=[];for(const ch of row){if(/\d/.test(ch)){for(let i=0;i<+ch;i++)rank.push('');}else{const pc=FEN_MAP[ch];if(!pc)return null;rank.push(pc);}}if(rank.length!==8)return null;board.push(rank);}
  return{board,turn:parts[1]==='b'?'b':'w'};
}

function buildHTML(){
  const grid=document.getElementById('puzzlesGrid');
  grid.innerHTML='';
  for(let i=0;i<4;i++){
    const cell=document.createElement('div');
    cell.className='puzzle-cell'+(i>=puzzleCount?' hidden':'');
    cell.id='cell-'+i;
    cell.innerHTML=`<div class="puzzle-num"><span class="puzzle-num-circle">${i+1}</span>Puzzle ${i+1}</div><div class="board-area"><div class="rank-labels" id="rl-${i}"></div><div class="board" id="board-${i}"></div><div></div><div class="file-labels" id="fl-${i}"></div></div><div class="puzzle-footer"><div class="turn"><div class="turn-dot" id="td-${i}"></div><div class="turn-text" id="tt-${i}">Trait aux blancs</div></div><div class="diff-stars" id="dstars-${i}"></div></div>`;
    grid.appendChild(cell);
  }
  const ctrlGrid=document.getElementById('controlsGrid');
  ctrlGrid.innerHTML='';
  for(let i=0;i<4;i++){
    const panel=document.createElement('div');
    panel.className='ctrl-panel'+(i>=puzzleCount?' hidden':'');
    panel.id='ctrl-'+i;
    const s=state[i];
    panel.innerHTML=`<div class="ctrl-title"><span class="ctrl-num">${i+1}</span>Puzzle ${i+1}</div>
<div class="fen-row"><input class="fen-input" id="fen-${i}" type="text" placeholder="FEN puzzle ${i+1}…"><button class="btn btn-gold" style="font-size:10px;padding:8px 14px" onclick="applyFen(${i})">Générer</button></div>
<div class="fen-error" id="ferr-${i}">❌ FEN invalide</div>
<div class="ctrl-row"><span class="ctrl-label">Trait</span><div class="toggle-group"><button class="toggle ${s.turn==='w'?'active':''}" id="tw-${i}" onclick="setTurn(${i},'w')">⬜ Blancs</button><button class="toggle ${s.turn==='b'?'active':''}" id="tb-${i}" onclick="setTurn(${i},'b')">⬛ Noirs</button></div></div>
<div class="ctrl-row"><span class="ctrl-label">Difficulté</span><div class="stars-ctrl" id="sc-${i}">${[1,2,3,4,5].map(v=>`<span class="star-c ${v<=s.difficulty?'on':'off'}" data-v="${v}">★</span>`).join('')}</div></div>`;
    ctrlGrid.appendChild(panel);
  }
  document.querySelectorAll('.stars-ctrl').forEach(sc=>{
    sc.addEventListener('click',e=>{const s=e.target.closest('.star-c');if(!s)return;setDifficulty(+sc.id.split('-')[1],+s.dataset.v);});
  });
}

function renderBoard(idx){
  const s=state[idx],pos=parseFen(s.fen);
  if(!pos)return;
  const f=s.turn==='b';
  const rl=document.getElementById('rl-'+idx);
  rl.innerHTML='';
  for(let r=0;r<8;r++){const d=document.createElement('div');d.className='rank-label';d.textContent=f?r+1:8-r;rl.appendChild(d);}
  const fl=document.getElementById('fl-'+idx);
  fl.innerHTML='';
  const files=f?['h','g','f','e','d','c','b','a']:['a','b','c','d','e','f','g','h'];
  files.forEach(lbl=>{const d=document.createElement('div');d.className='file-label';d.textContent=lbl;fl.appendChild(d);});
  const boardEl=document.getElementById('board-'+idx);
  boardEl.innerHTML='';
  for(let ri=0;ri<8;ri++){for(let fi=0;fi<8;fi++){const ari=f?7-ri:ri,afi=f?7-fi:fi,pc=pos.board[ari][afi];const sq=document.createElement('div');sq.className='square '+((ri+fi)%2===0?'light':'dark');if(pc&&PIECES_SVG[pc])sq.innerHTML=PIECES_SVG[pc];boardEl.appendChild(sq);}}
  const t=s.turn,dot=document.getElementById('td-'+idx),text=document.getElementById('tt-'+idx);
  if(t==='b'){dot.classList.add('black');text.textContent='Trait aux noirs';}else{dot.classList.remove('black');text.textContent='Trait aux blancs';}
  const ds=document.getElementById('dstars-'+idx);
  ds.innerHTML='';
  for(let i=1;i<=5;i++){const sp=document.createElement('span');sp.className='ds '+(i<=s.difficulty?'on':'off');sp.textContent='★';ds.appendChild(sp);}
}

function applyFen(idx){
  const val=document.getElementById('fen-'+idx).value.trim(),fen=val||DEFAULT_FENS[idx];
  const errEl=document.getElementById('ferr-'+idx),pos=parseFen(fen);
  if(!pos){errEl.style.display='block';return;}
  errEl.style.display='none';state[idx].fen=fen;setTurn(idx,pos.turn);renderBoard(idx);
}

function setTurn(idx,t){
  state[idx].turn=t;
  const tw=document.getElementById('tw-'+idx),tb=document.getElementById('tb-'+idx);
  if(tw){tw.classList.toggle('active',t==='w');tb.classList.toggle('active',t==='b');}
  renderBoard(idx);
}

function setDifficulty(idx,v){
  state[idx].difficulty=v;
  document.querySelectorAll('#sc-'+idx+' .star-c').forEach(s=>{s.className='star-c '+(+s.dataset.v<=v?'on':'off');});
  const ds=document.getElementById('dstars-'+idx);
  if(ds)ds.querySelectorAll('.ds').forEach((sp,i)=>{sp.className='ds '+(i+1<=v?'on':'off');});
}

function setPuzzleCount(n){
  puzzleCount=n;
  document.querySelectorAll('.count-btn').forEach(b=>b.classList.toggle('active',+b.dataset.n===n));
  for(let i=0;i<4;i++){document.getElementById('cell-'+i).classList.toggle('hidden',i>=n);document.getElementById('ctrl-'+i).classList.toggle('hidden',i>=n);}
  const grid=document.getElementById('puzzlesGrid');
  grid.className='puzzles-grid count-'+n;
  const ctrlGrid=document.getElementById('controlsGrid');
  ctrlGrid.className='controls-grid'+(n===1?' count-1':'');
  updateDividers(n);

}

function updateDividers(n){
  const cols=n===1?1:2;
  const rows=Math.ceil(n/cols);
  for(let i=0;i<4;i++){
    const cell=document.getElementById('cell-'+i);
    cell.classList.remove('border-right','border-bottom');
    if(n<=1||i>=n)continue;
    const col=i%cols,row=Math.floor(i/cols);
    if(col<cols-1&&i<n)cell.classList.add('border-right');
    if(row<rows-1&&i+cols<n)cell.classList.add('border-bottom');
  }
}

function downloadPGN(){
  const today=new Date(),date=`${today.getFullYear()}.${String(today.getMonth()+1).padStart(2,'0')}.${String(today.getDate()).padStart(2,'0')}`;
  let pgn='';
  for(let i=0;i<puzzleCount;i++){const s=state[i],turn=s.turn==='b'?'noirs':'blancs';pgn+=`[Event "Puzzle ${i+1} Club Blitzstream"]\n[Site "Club Blitzstream"]\n[Date "${date}"]\n[White "?"]\n[Black "?"]\n[Result "*"]\n[SetUp "1"]\n[FEN "${s.fen}"]\n[PuzzleDifficulty "${s.difficulty}/5"]\n\n{ Puzzle ${i+1} — Trait aux ${turn} }\n\n*\n\n\n`;}
  const blob=new Blob([pgn],{type:'application/x-chess-pgn'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='puzzles-blitzstream.pgn';a.click();URL.revokeObjectURL(a.href);
}

