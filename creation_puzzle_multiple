<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Puzzles — Club Blitzstream</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Raleway:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:radial-gradient(ellipse at 40% 30%,#0e0e1c 0%,#050507 100%);min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:32px 24px;gap:24px;font-family:'Raleway',sans-serif}
.topbar{width:960px;display:flex;justify-content:space-between;align-items:center;background:linear-gradient(155deg,#17172a,#0e0e18);border-radius:14px;border:1px solid rgba(212,168,67,.15);padding:14px 22px;gap:16px}
.topbar-brand{display:flex;align-items:center;gap:10px;flex-shrink:0}
.topbar-icon{font-size:20px;color:#d4a843}
.topbar-name{font-family:'Playfair Display',serif;font-size:16px;font-weight:700;color:#e8d5a0}
.topbar-name em{font-style:italic;font-weight:400;color:#d4a843}
.topbar-sub{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:rgba(212,168,67,.4);margin-top:2px}
.count-selector{display:flex;align-items:center;gap:8px}
.count-label{font-size:9px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:rgba(212,168,67,.45);white-space:nowrap}
.count-btns{display:flex;gap:4px}
.count-btn{font-family:'Raleway',sans-serif;font-size:12px;font-weight:700;width:30px;height:30px;border-radius:8px;border:1px solid rgba(212,168,67,.18);background:rgba(255,255,255,.03);color:#5a5570;cursor:pointer;transition:all .18s;display:flex;align-items:center;justify-content:center}
.count-btn.active{background:rgba(212,168,67,.16);border-color:rgba(212,168,67,.45);color:#d4a843}
.count-btn:hover:not(.active){background:rgba(212,168,67,.08);color:#a0956e}
.topbar-actions{display:flex;gap:10px;flex-shrink:0}
.btn{font-family:'Raleway',sans-serif;font-size:11px;font-weight:600;letter-spacing:1px;border:none;border-radius:10px;padding:10px 18px;cursor:pointer;transition:all .2s;white-space:nowrap}
.btn-gold{background:linear-gradient(135deg,#d4a843,#c49530);color:#0b0b14}
.btn-gold:hover{background:linear-gradient(135deg,#e0b84e,#d4a843);transform:translateY(-1px)}
.btn-outline{background:rgba(212,168,67,.08);border:1px solid rgba(212,168,67,.25);color:#d4a843}
.btn-outline:hover{background:rgba(212,168,67,.15);transform:translateY(-1px)}
.card{width:960px;background:linear-gradient(155deg,#17172a 0%,#0e0e18 60%,#0b0b14 100%);border-radius:22px;overflow:hidden;position:relative;box-shadow:0 0 0 1px rgba(212,168,67,.18),0 0 80px rgba(212,168,67,.06),0 40px 100px rgba(0,0,0,.8);animation:appear .6s cubic-bezier(.22,1,.36,1) both}
@keyframes appear{from{opacity:0;transform:translateY(16px) scale(.98)}to{opacity:1;transform:none}}
.card::before{content:'';display:block;height:2px;background:linear-gradient(90deg,transparent,#d4a843,#f0c96a,#d4a843,transparent)}
.card::after{content:'';position:absolute;inset:0;border-radius:22px;background:radial-gradient(ellipse at 50% 0%,rgba(212,168,67,.05) 0%,transparent 55%);pointer-events:none}
.card-header{padding:22px 32px 18px;display:flex;justify-content:space-between;align-items:center}
.brand{display:flex;align-items:center;gap:10px}
.brand-icon{font-size:22px;color:#d4a843}
.brand-name{font-family:'Playfair Display',serif;font-size:18px;font-weight:700;color:#e8d5a0;line-height:1}
.brand-name em{font-style:italic;font-weight:400;color:#d4a843}
.brand-sub{font-size:9px;font-weight:500;letter-spacing:3px;text-transform:uppercase;color:rgba(212,168,67,.45);margin-top:3px}
.puzzle-tag{font-size:10px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#d4a843;background:rgba(212,168,67,.08);border:1px solid rgba(212,168,67,.22);border-radius:30px;padding:5px 14px}
.header-sep{height:1px;background:linear-gradient(90deg,transparent,rgba(212,168,67,.12),transparent);margin:0 32px}
.puzzles-grid{display:grid;grid-template-columns:1fr 1fr;padding:0 32px 28px;position:relative}
.puzzles-grid.count-1{grid-template-columns:1fr;max-width:480px;margin:0 auto;width:100%}
.puzzles-grid.count-2{grid-template-columns:1fr 1fr}
.puzzle-cell{padding:20px 20px 18px;transition:opacity .3s}
.puzzle-cell.hidden{display:none}
.puzzle-cell.border-right{border-right:1px solid rgba(212,168,67,.1)}
.puzzle-cell.border-bottom{border-bottom:1px solid rgba(212,168,67,.1)}
.puzzle-num{display:flex;align-items:center;gap:7px;font-size:9px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:rgba(212,168,67,.5);margin-bottom:10px}.puzzles-grid.count-1 .puzzle-num{display:none}
.puzzle-num-circle{width:18px;height:18px;border-radius:50%;background:rgba(212,168,67,.12);border:1px solid rgba(212,168,67,.3);display:flex;align-items:center;justify-content:center;font-size:9px;line-height:18px;font-weight:700;color:#d4a843;flex-shrink:0;padding-bottom:1px}
.board-area{display:grid;grid-template-columns:14px 1fr;grid-template-rows:1fr 14px;margin-bottom:10px}
.rank-labels{grid-column:1;grid-row:1;display:flex;flex-direction:column}
.rank-label{flex:1;display:flex;align-items:center;justify-content:center;font-size:9px;color:#38385a}
.board{grid-column:2;grid-row:1;display:grid;grid-template-columns:repeat(8,1fr);grid-template-rows:repeat(8,1fr);border-radius:4px;overflow:hidden;box-shadow:0 0 0 1px rgba(0,0,0,.5),0 6px 24px rgba(0,0,0,.5);aspect-ratio:1}
.square{display:flex;align-items:center;justify-content:center;overflow:hidden;min-width:0;min-height:0}
.square.light{background:#f0d9b5}
.square.dark{background:#b58863}
.square svg{width:80%;height:80%;flex-shrink:0}
.file-labels{grid-column:2;grid-row:2;display:grid;grid-template-columns:repeat(8,1fr);padding-top:3px}
.file-label{text-align:center;font-size:9px;color:#38385a}
.puzzle-footer{display:flex;justify-content:space-between;align-items:center}
.turn{display:flex;align-items:center;gap:8px}
.turn-dot{width:11px;height:11px;border-radius:50%;background:radial-gradient(circle at 35% 35%,#fff,#d0d0d0);box-shadow:0 0 0 1px rgba(0,0,0,.3),0 0 8px rgba(255,255,255,.4);flex-shrink:0;transition:all .3s}
.turn-dot.black{background:radial-gradient(circle at 35% 35%,#555,#111);box-shadow:0 0 0 1px rgba(255,255,255,.15)}
.turn-text{font-family:'Playfair Display',serif;font-style:italic;font-size:12px;color:#c8bea4}
.diff-stars .ds{font-size:13px;line-height:1}
.diff-stars .ds.on{color:#d4a843;filter:drop-shadow(0 0 3px rgba(212,168,67,.5))}
.diff-stars .ds.off{color:#1e1e30}
.controls-grid{width:960px;display:grid;grid-template-columns:1fr 1fr;gap:14px;transition:all .3s}
.controls-grid.count-1{grid-template-columns:1fr;max-width:480px;margin:0 auto;width:100%}
.ctrl-panel{background:linear-gradient(155deg,#17172a,#0e0e18);border-radius:14px;border:1px solid rgba(212,168,67,.13);padding:16px 18px;display:flex;flex-direction:column;gap:11px;transition:opacity .3s}
.ctrl-panel.hidden{display:none}
.ctrl-title{font-size:9px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:rgba(212,168,67,.45);display:flex;align-items:center;gap:7px}
.ctrl-num{width:16px;height:16px;border-radius:50%;background:rgba(212,168,67,.12);border:1px solid rgba(212,168,67,.3);display:inline-flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;color:#d4a843}
.fen-row{display:flex;gap:8px}
.fen-input{flex:1;background:rgba(255,255,255,.04);border:1px solid rgba(212,168,67,.2);border-radius:8px;padding:8px 12px;font-family:'Raleway',sans-serif;font-size:10px;color:#c8bea4;outline:none;transition:border-color .2s}
.fen-input::placeholder{color:rgba(200,190,164,.25)}
.fen-input:focus{border-color:rgba(212,168,67,.5)}
.fen-error{font-size:9px;color:#e07070;display:none}
.ctrl-row{display:flex;align-items:center;gap:10px}
.ctrl-label{font-size:9px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:rgba(212,168,67,.4);width:75px;flex-shrink:0}
.toggle-group{display:flex;gap:5px;flex-wrap:wrap}
.toggle{font-family:'Raleway',sans-serif;font-size:9px;font-weight:600;padding:5px 11px;border-radius:7px;border:1px solid rgba(212,168,67,.15);background:rgba(255,255,255,.03);color:#5a5570;cursor:pointer;transition:all .2s}
.toggle.active{background:rgba(212,168,67,.14);border-color:rgba(212,168,67,.4);color:#d4a843}
.toggle:hover:not(.active){background:rgba(212,168,67,.07);color:#a0956e}
.stars-ctrl{display:flex;gap:1px}
.star-c{font-size:17px;line-height:1;cursor:pointer;transition:transform .1s;user-select:none}
.star-c:hover{transform:scale(1.2)}
.star-c.on{color:#d4a843;filter:drop-shadow(0 0 4px rgba(212,168,67,.5))}
.star-c.off{color:#1e1e30}
</style>
</head>
<body>

<div class="topbar">
  <div class="topbar-brand">
    <div class="topbar-icon">♟</div>
    <div>
      <div class="topbar-name">Club <em>Blitzstream</em></div>
      <div class="topbar-sub">Puzzles du jour</div>
    </div>
  </div>
  <div class="count-selector">
    <span class="count-label">Nb de puzzles</span>
    <div class="count-btns">
      <button class="count-btn" data-n="1" onclick="setPuzzleCount(1)">1</button>
      <button class="count-btn" data-n="2" onclick="setPuzzleCount(2)">2</button>
      <button class="count-btn" data-n="3" onclick="setPuzzleCount(3)">3</button>
      <button class="count-btn active" data-n="4" onclick="setPuzzleCount(4)">4</button>
    </div>
  </div>
  <div class="topbar-actions">
    <button class="btn btn-outline" onclick="downloadPGN()">⬇ PGN</button>
    <button class="btn btn-gold" id="pngBtn" onclick="downloadPNG()">🖼 PNG</button>
  </div>
</div>


<div class="controls-grid" id="controlsGrid"></div>


<div class="card" id="card">
  <div class="card-header">
    <div class="brand">
      <div class="brand-icon">♟</div>
      <div>
        <div class="brand-name">Club <em>Blitzstream</em></div>
        <div class="brand-sub">Puzzles du jour</div>
      </div>
    </div>
    <div class="puzzle-tag">Tactique</div>
  </div>
  <div class="header-sep"></div>
  <div class="puzzles-grid count-4" id="puzzlesGrid"></div>
</div>

