<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Diagramme — Club Blitzstream</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Raleway:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }
body {
  background: radial-gradient(ellipse at 40% 30%, #0e0e1c 0%, #050507 100%);
  min-height:100vh; display:flex; flex-direction:column;
  align-items:center; justify-content:center;
  padding:32px 24px; gap:20px; font-family:'Raleway',sans-serif;
}

/* ── CONTROLS ── */
.controls {
  width:500px;
  background:linear-gradient(155deg,#17172a,#0e0e18);
  border-radius:16px; border:1px solid rgba(212,168,67,.15);
  padding:20px 24px; display:flex; flex-direction:column; gap:14px;
}
.controls-title {
  font-size:10px; font-weight:600; letter-spacing:3px;
  text-transform:uppercase; color:rgba(212,168,67,.5);
}
.fen-row { display:flex; gap:10px; }
.fen-input {
  flex:1; background:rgba(255,255,255,.04);
  border:1px solid rgba(212,168,67,.2); border-radius:10px;
  padding:10px 14px; font-family:'Raleway',sans-serif; font-size:11px;
  color:#c8bea4; outline:none; transition:border-color .2s;
}
.fen-input::placeholder { color:rgba(200,190,164,.3); }
.fen-input:focus { border-color:rgba(212,168,67,.5); }
.fen-error { font-size:10px; color:#e07070; display:none; }
.btn {
  font-family:'Raleway',sans-serif; font-size:11px; font-weight:600;
  letter-spacing:1px; border:none; border-radius:10px;
  padding:10px 18px; cursor:pointer; transition:all .2s; white-space:nowrap;
}
.btn-gold { background:linear-gradient(135deg,#d4a843,#c49530); color:#0b0b14; }
.btn-gold:hover { background:linear-gradient(135deg,#e0b84e,#d4a843); transform:translateY(-1px); }
.btn-outline { background:rgba(212,168,67,.08); border:1px solid rgba(212,168,67,.25); color:#d4a843; }
.btn-outline:hover { background:rgba(212,168,67,.15); transform:translateY(-1px); }
.actions-row { display:flex; gap:10px; }

/* ── ORIENTATION ── */
.ctrl-row { display:flex; align-items:center; gap:12px; }
.ctrl-label { font-size:9px; font-weight:600; letter-spacing:2px; text-transform:uppercase; color:rgba(212,168,67,.4); width:80px; flex-shrink:0; }
.toggle-group { display:flex; gap:6px; }
.toggle { font-family:'Raleway',sans-serif; font-size:10px; font-weight:600; padding:6px 12px; border-radius:8px; border:1px solid rgba(212,168,67,.15); background:rgba(255,255,255,.03); color:#5a5570; cursor:pointer; transition:all .2s; }
.toggle.active { background:rgba(212,168,67,.14); border-color:rgba(212,168,67,.4); color:#d4a843; }
.toggle:hover:not(.active) { background:rgba(212,168,67,.07); color:#a0956e; }

/* ── CARD ── */
.card {
  width:500px;
  background:linear-gradient(155deg,#17172a 0%,#0e0e18 60%,#0b0b14 100%);
  border-radius:22px; overflow:hidden; position:relative;
  box-shadow:0 0 0 1px rgba(212,168,67,.18),0 0 60px rgba(212,168,67,.07),0 30px 90px rgba(0,0,0,.8);
  animation:appear .6s cubic-bezier(.22,1,.36,1) both;
}
@keyframes appear { from{opacity:0;transform:translateY(14px) scale(.98)} to{opacity:1;transform:none} }
.card::before { content:''; display:block; height:2px; background:linear-gradient(90deg,transparent,#d4a843,#f0c96a,#d4a843,transparent); }
.card::after { content:''; position:absolute; inset:0; border-radius:22px; background:radial-gradient(ellipse at 50% 0%,rgba(212,168,67,.06) 0%,transparent 60%); pointer-events:none; }

.card-header { padding:20px 28px 16px; display:flex; justify-content:space-between; align-items:center; }
.brand { display:flex; align-items:center; gap:10px; }
.brand-icon { font-size:22px; color:#d4a843; }
.brand-name { font-family:'Playfair Display',serif; font-size:17px; font-weight:700; color:#e8d5a0; line-height:1; }
.brand-name em { font-style:italic; font-weight:400; color:#d4a843; }
.brand-sub { font-size:9px; font-weight:500; letter-spacing:3px; text-transform:uppercase; color:rgba(212,168,67,.45); margin-top:3px; }
.diag-tag { font-size:10px; font-weight:600; letter-spacing:2px; text-transform:uppercase; color:#d4a843; background:rgba(212,168,67,.08); border:1px solid rgba(212,168,67,.22); border-radius:30px; padding:5px 14px; }
.header-sep { height:1px; background:linear-gradient(90deg,transparent,rgba(212,168,67,.12),transparent); margin:0 28px; }

.board-section { padding:22px 28px 24px; }
.board-area { display:grid; grid-template-columns:16px 1fr; grid-template-rows:1fr 16px; }
.rank-labels { grid-column:1; grid-row:1; display:flex; flex-direction:column; }
.rank-label { flex:1; display:flex; align-items:center; justify-content:center; font-size:10px; color:#38385a; }
.board { grid-column:2; grid-row:1; display:grid; grid-template-columns:repeat(8,1fr); grid-template-rows:repeat(8,1fr); border-radius:5px; overflow:hidden; box-shadow:0 0 0 1px rgba(0,0,0,.6),0 10px 40px rgba(0,0,0,.6); aspect-ratio:1; }
.square { display:flex; align-items:center; justify-content:center; overflow:hidden; min-width:0; min-height:0; }
.square.light { background:#f0d9b5; }
.square.dark  { background:#b58863; }
.square svg { width:80%; height:80%; flex-shrink:0; }
.file-labels { grid-column:2; grid-row:2; display:grid; grid-template-columns:repeat(8,1fr); padding-top:4px; }
.file-label { text-align:center; font-size:10px; color:#38385a; }
</style>
</head>
<body>

<div class="controls">
  <div class="controls-title">⚙ Générer un diagramme</div>
  <div class="fen-row">
    <input class="fen-input" id="fenInput" type="text" placeholder="Coller un FEN… ex: rnbqkbnr/pppppppp/8/8/4P3/8/PPPP1PPP/RNBQKBNR">
    <button class="btn btn-gold" onclick="applyFen()">Générer</button>
  </div>
  <div class="fen-error" id="fenError">❌ FEN invalide — vérifie le format.</div>
  <div class="ctrl-row">
    <span class="ctrl-label">Orientation</span>
    <div class="toggle-group">
      <button class="toggle active" id="toggleW" onclick="setFlip(false)">⬜ Blancs bas</button>
      <button class="toggle" id="toggleB" onclick="setFlip(true)">⬛ Noirs bas</button>
    </div>
  </div>
  <div class="ctrl-row">
    <span class="ctrl-label">Trait</span>
    <div class="toggle-group">
      <button class="toggle active" id="turnNone" onclick="setTurn('none')">— Aucun</button>
      <button class="toggle" id="turnW" onclick="setTurn('w')"><span style="display:inline-block;width:11px;height:11px;border-radius:50%;background:#fff;border:1.5px solid #888;vertical-align:middle;margin-right:4px"></span>Blancs</button>
      <button class="toggle" id="turnB" onclick="setTurn('b')"><span style="display:inline-block;width:11px;height:11px;border-radius:50%;background:#111;border:1.5px solid rgba(255,255,255,.3);vertical-align:middle;margin-right:4px"></span>Noirs</button>
    </div>
  </div>
  <div class="actions-row">
    <button class="btn btn-gold" id="pngBtn" onclick="downloadPNG()">🖼 Télécharger PNG</button>
  </div>
</div>

<div class="card" id="card">
  <div class="card-header">
    <div class="brand">
      <div class="brand-icon">♟</div>
      <div>
        <div class="brand-name">Club <em>Blitzstream</em></div>
        
      </div>
    </div>
    <div class="diag-tag">Position</div>
  </div>
  <div class="header-sep"></div>
  <div class="board-section">
    <div class="board-area">
      <div class="rank-labels" id="rankLabels"></div>
      <div class="board" id="board"></div>
      <div></div>
      <div class="file-labels" id="fileLabels"></div>
    </div>
  </div>
  <div class="card-footer" id="cardFooter" style="display:none;padding:0 28px 20px">
    <div class="turn-dot" id="turnDot"></div>
  </div>
</div>

